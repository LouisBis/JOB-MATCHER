# =============================================================================
# .env.example — Job Matcher configuration template
# Copy to .env and fill in your values: cp .env.example .env
# Never commit .env to git.
# =============================================================================

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=          # Required — choose a strong password

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b           # Recommended: fast on Apple Silicon. Pull with: ollama pull llama3.2:3b

# ── Apify (job source) ────────────────────────────────────────────────────────
APIFY_TOKEN=                       # From apify.com → Settings → Integrations
APIFY_ACTOR_ID=valig~indeed-jobs-scraper
APIFY_QUERY=frontend developer     # Job title / keywords
APIFY_LOCATION=Paris, France       # Search location
APIFY_COUNTRY=fr                   # Country code (see apify actor docs for valid values)
APIFY_MAX_ITEMS=50                 # Max offers fetched per run
APIFY_DATE_POSTED=7                # Valid values: 1 | 3 | 7 | 14 (days since posting)
FETCH_CRON=0 */3 * * *             # How often to check for new offers (default: every 3h)

# ── France Travail (direct API, optional) ─────────────────────────────────────
FT_CLIENT_ID=                      # francetravail.io → My applications → Client ID
FT_CLIENT_SECRET=                  # francetravail.io → My applications → Client Secret
FT_DEPARTEMENT=75                  # Department code: 75=Paris, 69=Lyon, 13=Marseille…
                                   # Leave FT_CLIENT_ID empty to disable this source

# ── Scoring ───────────────────────────────────────────────────────────────────
FILTER_EXCLUDE=                    # Comma-separated title keywords to skip before LLM (e.g. java,python,devops)
MIN_SCORE=7                        # Offers below this score are saved but not sent
